{
  "name": "hops-and-harmonies",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sh -c 'P=$(lsof -ti :4000); [ -n \"$P\" ] && kill $P 2>/dev/null; true' && bun run --watch brewbeats/backend/index.ts",
    "dev:ui": "cd brewbeats/ui && npm run dev",
    "dev:all": "./dev.sh",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "latest"
  }
}
